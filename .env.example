## Copy to `private/secrets.env` (recommended) or `.env` (also works).
## Never commit real secrets.

# Choose provider for LLM calls: "ollama" or "anthropic"
AI_PROVIDER=anthropic

## Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBED_MODEL=nomic-embed-text

## Anthropic (hosted)
# ANTHROPIC_API_KEY=sk-ant-api03-...   (must start with sk-ant-)
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: enable Ollama dense retrieval in RAG scripts
# python predictive_models/hybrid_rag_predictor.py --use-embeddings
